rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isSupervisor(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isLinkedStudent(supervisorId, clinicianId) {
      return isAuth()
        && userRole() == 'student'
        && get(/databases/$(database)/documents/supervisors/$(supervisorId)/clinicians/$(clinicianId)).data.studentEmail
           == request.auth.token.email;
    }

    // Student has an archived semester pointer for this supervisor + semId.
    // Used to allow read access to archived supervisor data.
    function studentHasArchivePointer(supervisorId, semId) {
      let email = request.auth.token.email;
      return isAuth()
        && userRole() == 'student'
        && exists(/databases/$(database)/documents/studentHistory/$(email)/semesters/$(semId))
        && get(/databases/$(database)/documents/studentHistory/$(email)/semesters/$(semId)).data.supervisorId == supervisorId;
    }


    // ── User profile docs ─────────────────────────────────────────────────────

    match /users/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }


    // ── Student links ─────────────────────────────────────────────────────────

    match /studentLinks/{email} {
      allow read:  if isAuth() && request.auth.token.email == email;
      allow write: if isAuth() && userRole() == 'supervisor';
    }


    // ── Student semester history pointers ─────────────────────────────────────
    // Supervisors write during archiving; students read their own history.

    match /studentHistory/{email}/semesters/{semId} {
      allow read:  if isAuth() && request.auth.token.email == email;
      allow write: if isAuth() && userRole() == 'supervisor';
    }


    // ── Supervisor data ───────────────────────────────────────────────────────

    match /supervisors/{supervisorId} {

      // Semester settings — supervisor only
      match /settings/{docId} {
        allow read, write: if isSupervisor(supervisorId);
      }

      // Clinicians — supervisor full access; linked student read-only
      match /clinicians/{clinicianId} {
        allow read, write: if isSupervisor(supervisorId);
        allow read:        if isAuth()
                              && userRole() == 'student'
                              && resource.data.studentEmail == request.auth.token.email;
      }

      // Observations — supervisor full access; linked student read-only
      match /observations/{obsId} {
        allow read, write: if isSupervisor(supervisorId);
        allow read:        if isLinkedStudent(supervisorId, resource.data.clinicianId);
      }

      // Evaluations — supervisor full access; linked student read-only
      match /evaluations/{evalId} {
        allow read, write: if isSupervisor(supervisorId);
        allow read:        if isLinkedStudent(supervisorId, resource.data.clinicianId);
      }

      // ITPs — supervisor full access; linked student read + update
      match /itps/{itpId} {
        allow read, write: if isSupervisor(supervisorId);
        allow read:        if isLinkedStudent(supervisorId, resource.data.clinicianId);
        allow update:      if isAuth()
          && userRole() == 'student'
          && isLinkedStudent(supervisorId, resource.data.clinicianId)
          && request.resource.data.clinicianId == resource.data.clinicianId;
      }

      // SOAP Notes — supervisor full access; linked student read + write own notes
      match /soapNotes/{noteId} {
        allow read, write: if isSupervisor(supervisorId);
        allow read:        if isLinkedStudent(supervisorId, resource.data.clinicianId);
        allow create:      if isAuth()
          && userRole() == 'student'
          && isLinkedStudent(supervisorId, request.resource.data.clinicianId);
        allow update:      if isAuth()
          && userRole() == 'student'
          && isLinkedStudent(supervisorId, resource.data.clinicianId)
          && request.resource.data.clinicianId == resource.data.clinicianId;
      }


      // ── Archived semesters ────────────────────────────────────────────────
      // Supervisor: full read/write.
      // Student: read-only if they have an archive pointer for this semId.
      // All archived data is immutable from the student's perspective.

      match /archivedSemesters/{semId} {
        allow read, write: if isSupervisor(supervisorId);
        allow read:        if studentHasArchivePointer(supervisorId, semId);

        match /clinicians/{clinicianId} {
          allow read, write: if isSupervisor(supervisorId);
          allow read:        if studentHasArchivePointer(supervisorId, semId);
        }

        match /observations/{obsId} {
          allow read, write: if isSupervisor(supervisorId);
          allow read:        if studentHasArchivePointer(supervisorId, semId);
        }

        match /evaluations/{evalId} {
          allow read, write: if isSupervisor(supervisorId);
          allow read:        if studentHasArchivePointer(supervisorId, semId);
        }

        match /itps/{itpId} {
          allow read, write: if isSupervisor(supervisorId);
          allow read:        if studentHasArchivePointer(supervisorId, semId);
        }

        match /soapNotes/{noteId} {
          allow read, write: if isSupervisor(supervisorId);
          allow read:        if studentHasArchivePointer(supervisorId, semId);
        }
      }
    }
  }
}
